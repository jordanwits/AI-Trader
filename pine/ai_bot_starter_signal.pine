//@version=5
indicator("AI Bot Starter Signal", overlay=true, max_boxes_count=500, max_labels_count=500)

// Inputs (conservative defaults - fewer but higher-quality signals)
stop_atr_mult = input.float(2.0, "Stop ATR Multiplier", minval=0.5, step=0.1, tooltip="Higher = wider stop, fewer false stops")
rsi_ob = input.int(70, "RSI Overbought", minval=50, maxval=90, tooltip="Lower = avoid longs in overbought zone")
rsi_os = input.int(30, "RSI Oversold", minval=10, maxval=50, tooltip="Higher = avoid shorts in oversold zone")
min_adx = input.int(18, "Min ADX (Trend Strength)", minval=5, maxval=50, tooltip="Higher = require stronger trend")
vol_mult = input.float(1.05, "Volume Multiplier", minval=0.5, step=0.05, tooltip="Higher = require above-avg volume")
use_vwap_filter = input.bool(true, "Use VWAP Filter", tooltip="On = long above VWAP, short below VWAP only")

// Market hours (US equities) - avoid new signals near close
use_market_hours_filter = input.bool(true, "Block Signals Near Market Close", group="Market Hours", tooltip="On = no new signals in last N min of session")
mins_before_close = input.int(45, "Minutes Before Close to Stop Signals", minval=15, maxval=120, group="Market Hours", tooltip="No new entries in last N min before 4 PM ET")

// Indicators
ema9 = ta.ema(close, 9)
ema21 = ta.ema(close, 21)
vwap_val = ta.vwap(close)
rsi_val = ta.rsi(close, 14)
atr_val = ta.atr(14)

// ADX for trend strength
[diplus, diminus, adx_val] = ta.dmi(14, 14)

// Volume filter
vol_avg = ta.sma(volume, 20)
vol_spike = volume > vol_avg * vol_mult

// Improved Signals with filters (VWAP optional when use_vwap_filter off)
vwap_ok_long = use_vwap_filter ? close > vwap_val : true
vwap_ok_short = use_vwap_filter ? close < vwap_val : true

// US session: block signals within N min of 4 PM ET (avoid late entries that get dumped at close)
ny_h = hour(time, "America/New_York")
ny_m = minute(time, "America/New_York")
ny_minutes = ny_h * 60 + ny_m
close_minutes = 16 * 60  // 4 PM ET
ok_time = not (timeframe.isintraday and use_market_hours_filter and ny_minutes >= close_minutes - mins_before_close)

longSignal = ta.crossover(ema9, ema21) and vwap_ok_long and rsi_val < rsi_ob and adx_val > min_adx and vol_spike and ok_time
shortSignal = ta.crossunder(ema9, ema21) and vwap_ok_short and rsi_val > rsi_os and adx_val > min_adx and vol_spike and ok_time

// ATR-based stops (adapts to volatility). Ensure short_stop > close (min 0.01% gap for shorts).
min_short_gap = close * 0.0001
short_stop_raw = close + (atr_val * stop_atr_mult)
long_stop = close - (atr_val * stop_atr_mult)
short_stop = short_stop_raw > close + min_short_gap ? short_stop_raw : close + min_short_gap

// Better interval formatting
getInterval() =>
    if timeframe.isintraday
        str.tostring(timeframe.multiplier) + "m"
    else if timeframe.isdaily
        "1D"
    else if timeframe.isweekly
        "1W"
    else if timeframe.ismonthly
        "1M"
    else
        str.tostring(timeframe.multiplier) + timeframe.period

intervalStr = getInterval()

// Unique alert ID using timestamp
alertId = str.tostring(timenow)

// Build JSON payload
buildLongJson() =>
    '{"alert_id":"' + alertId + '","ticker":"' + syminfo.ticker + '","timeframe":"' + intervalStr + '","action":"BUY","price":' + str.tostring(close) + ',"stop":' + str.tostring(long_stop) + ',"atr":' + str.tostring(atr_val) + ',"meta":{"ema9":' + str.tostring(ema9) + ',"ema21":' + str.tostring(ema21) + ',"vwap":' + str.tostring(vwap_val) + ',"rsi":' + str.tostring(rsi_val) + ',"adx":' + str.tostring(adx_val) + ',"volume":' + str.tostring(volume) + ',"vol_avg":' + str.tostring(vol_avg) + '}}'

buildShortJson() =>
    '{"alert_id":"' + alertId + '","ticker":"' + syminfo.ticker + '","timeframe":"' + intervalStr + '","action":"SELL","price":' + str.tostring(close) + ',"stop":' + str.tostring(short_stop) + ',"atr":' + str.tostring(atr_val) + ',"meta":{"ema9":' + str.tostring(ema9) + ',"ema21":' + str.tostring(ema21) + ',"vwap":' + str.tostring(vwap_val) + ',"rsi":' + str.tostring(rsi_val) + ',"adx":' + str.tostring(adx_val) + ',"volume":' + str.tostring(volume) + ',"vol_avg":' + str.tostring(vol_avg) + '}}'

// Plot
plot(ema9, "EMA 9", color=color.blue, linewidth=2)
plot(ema21, "EMA 21", color=color.orange, linewidth=2)
plot(vwap_val, "VWAP", color=color.purple, linewidth=1)

// Visual markers
plotshape(longSignal, "Long", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(shortSignal, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)

// Alert triggers - use these when creating webhook alerts.
// Create alert on this indicator, choose "Once Per Bar Close", set Webhook URL.
if longSignal
    alert(buildLongJson(), alert.freq_once_per_bar_close)

if shortSignal
    alert(buildShortJson(), alert.freq_once_per_bar_close)
